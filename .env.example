# OpenAI — Sora video generation (Videos API)
OPENAI_API_KEY=sk-...

# Modal — only for upscaling. Preferred: run `uv run modal setup` once, which
# stores credentials in ~/.modal.toml (no .env entry needed). Alternatively,
# paste an API token from modal.com → Settings → API Tokens:
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...
